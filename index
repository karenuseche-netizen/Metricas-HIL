function SC(r){return r>=70?'score-hi':r>=50?'score-md':'score-lo';}
function SL(r){return r>=70?'Alto':r>=50?'Medio':'Bajo';}
function RC(i){return i===0?'gold':i===1?'silver':i===2?'bronze':'';}

function renderAgentsTab(d){
  var agents=d.topAgents;if(!agents||!agents.length)return;
  var totAll=agents.reduce(function(s,a){return s+a.count;},0);
  var aprAll=agents.reduce(function(s,a){return s+(a.apr||0);},0);
  var top=agents[0];
  var fastest=agents.filter(function(a){return a.avgTime>0;}).sort(function(a,b){return a.avgTime-b.avgTime;})[0];
  document.getElementById('ag-kpi-count').textContent=agents.length;
  document.getElementById('ag-kpi-top').textContent=top.name;
  document.getElementById('ag-kpi-top-sub').textContent=fmt(top.count)+' casos';
  document.getElementById('ag-kpi-apr-rate').textContent=pct(aprAll,totAll);
  if(fastest){document.getElementById('ag-kpi-fast').textContent=minStr(fastest.avgTime);document.getElementById('ag-kpi-fast-sub').textContent=fastest.name;}

  document.getElementById('ag-detail-tbody').innerHTML=agents.map(function(a,i){
    var aprR=pctN(a.apr||0,a.count);var rejR=pctN(a.rej||0,a.count);
    var wg=Math.round((a.apr||0)/a.count*96);var wr2=Math.round((a.rej||0)/a.count*96);var wa=96-wg-wr2;
    var tStr=a.avgTime>0?minStr(a.avgTime):'N/A';
    var slaPctCard=a.slaPct||0;var slaTotCard=(a.slaOk||0)+(a.slaOver||0);
    var slaStr=slaTotCard>0?slaPctCard.toFixed(0)+'% SLA':'N/A';
    var slaColorCard=slaPctCard>=95?'#10B981':slaPctCard>=80?'#F59E0B':'#EF4444';
    var tColor=a.avgTime>90?'#F59E0B':a.avgTime>0?'#10B981':'#9CA3AF';
    var slaPct=a.slaPct||0;var slaTot=(a.slaOk||0)+(a.slaOver||0);
    var slaCell=slaTot>0?'<span class="'+(slaPct>=95?'sla-ok':slaPct>=80?'sla-warn':'sla-bad')+'">'+slaPct.toFixed(0)+'%</span>':'<span style="color:#9CA3AF">N/A</span>';
    return '<tr>' +
      '<td><div class="rank-badge '+RC(i)+'">'+(i+1)+'</div></td>' +
      '<td><div style="display:flex;align-items:center;gap:12px"><div class="av" style="background:'+AC[i%AC.length]+'">'+ini(a.name)+'</div>' +
      '<div><div style="font-weight:700;font-size:15px">'+a.name+'</div>' +
      '<div style="font-size:12px;color:var(--gray-500)">'+pct(a.count,totAll)+' del total</div></div></div></td>' +
      '<td class="tr"><strong style="font-size:15px">'+fmt(a.count)+'</strong></td>' +
      '<td class="tr"><span style="color:#10B981;font-weight:800">'+fmt(a.apr||0)+'</span></td>' +
