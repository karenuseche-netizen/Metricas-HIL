  options:{responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:false},
      tooltip:{callbacks:{label:function(c){return c.parsed.y+' min';}}},
      annotation:{annotations:{slaLine:{type:'line',scaleID:'y',value:60,borderColor:'#3B82F6',borderWidth:2,borderDash:[6,3],label:{content:'60 casos/hora',enabled:true,position:'end',backgroundColor:'#EF4444',font:{size:11,weight:'700'}}}}}
