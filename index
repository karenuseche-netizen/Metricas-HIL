function normRes(v){
  const s=String(v||'').toLowerCase().trim();
  if(['approved','aprobado','ok','si','yes','true','1','pass','accepted'].some(k=>s===k||s.includes(k)))return'Aprobado';
  if(['disapproved','rechazado','no','false','0','fail','denied','rejected'].some(k=>s===k||s.includes(k)))return'Rechazado';
  if(['incomplete','incompleto','pending','pendiente','partial'].some(k=>s===k||s.includes(k)))return'Incompleto';
  return'Otro';
}
function parseDate(v){
  if(!v)return null;
