function updateMonths(d){
  Object.values(cMonths).forEach(function(c){if(c)c.destroy();});
  Object.keys(cMonths).forEach(function(k){delete cMonths[k];});
  var months=Object.keys(d.monthMap).sort();
  var COLORS=['#10B981','#3B82F6','#F59E0B','#8B5CF6','#EF4444','#06B6D4'];
  var html=months.map(function(m,i){
    var v=d.monthMap[m];var tot=v.apr+v.rej+v.inc;
    var parts=m.split('-');var yr=parts[0];var mo=parts[1];
    var nm=MONTHS_ES[parseInt(mo)-1]+' '+yr;
    return '<div class="card"><div class="c-head"><div class="chl"><span class="c-bar" style="background:'+COLORS[i%COLORS.length]+'"></span>'+nm+'</div></div><div class="c-body"><div class="mini-stats"><div class="mini mg"><div class="mini-val">'+fmt(v.apr)+'</div><div class="mini-lbl">Aprobados &middot; '+pct(v.apr,tot)+'</div></div><div class="mini mr"><div class="mini-val">'+fmt(v.rej)+'</div><div class="mini-lbl">Rechazados &middot; '+pct(v.rej,tot)+'</div></div><div class="mini mb"><div class="mini-val">'+fmt(tot)+'</div><div class="mini-lbl">Total del mes</div></div></div><div style="position:relative;height:110px"><canvas id="chM-'+m+'"></canvas></div></div></div>';
  }).join('');
  document.getElementById('monthly-container').innerHTML=html;
  months.forEach(function(m){
    var v=d.monthMap[m];var el=document.getElementById('chM-'+m);if(!el)return;
    cMonths[m]=new Chart(el.getContext('2d'),{type:'doughnut',data:{labels:['Aprobados','Rechazados','Incompletos'],datasets:[{data:[v.apr,v.rej,v.inc],backgroundColor:['#10B981','#EF4444','#F59E0B'],borderWidth:3,borderColor:'#fff',hoverOffset:5}]},options:{responsive:true,maintainAspectRatio:false,cutout:'65%',plugins:{legend:{display:false},tooltip:{callbacks:{label:function(c){return ' '+c.label+': '+c.parsed.toLocaleString('es');}}}}}});
  });
}

