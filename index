function switchTab(name,btn){
  document.querySelectorAll('.tab-pane').forEach(function(p){p.classList.remove('active');});
  document.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active');});
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
  if(GDATA){
    if(name==='agentes')setTimeout(function(){renderAgentsTab(GDATA);},40);
    if(name==='motivos')setTimeout(function(){renderMotivosTab(GDATA);},40);
    if(name==='tiempo')setTimeout(function(){renderTiempoTab(GDATA);},40);
  }
}

function updateKPIs(d){
  document.getElementById('kpi-total').textContent=fmt(d.total);
  document.getElementById('kpi-apr').textContent=fmt(d.totalApr);
  document.getElementById('kpi-rej').textContent=fmt(d.totalRej);
  document.getElementById('kpi-inc').textContent=fmt(d.totalInc);
  document.getElementById('kpi-prom').textContent=fmt(d.promDiario);
  document.getElementById('kpi-apr-badge').textContent=pct(d.totalApr,d.total);
  document.getElementById('kpi-rej-badge').textContent=pct(d.totalRej,d.total);
  document.getElementById('kpi-inc-badge').textContent=pct(d.totalInc,d.total);
  document.getElementById('kpi-total-sub').textContent=d.periodo||'';
  document.getElementById('kpi-prom-sub').textContent=d.maxDayDate?'Max: '+fmt(d.maxDayVal)+' casos ('+d.maxDayDate+')':'';
  document.getElementById('hdr-periodo').textContent=d.periodo||'';
  document.getElementById('hdr-prom').textContent=fmt(d.promDiario)+' casos';
  document.getElementById('hdr-total').textContent=fmt(d.total);
}

