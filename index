<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Human in the Loop 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{
  --blue:#3B82F6;--green:#10B981;--red:#EF4444;--amber:#F59E0B;--purple:#8B5CF6;
  --gray-50:#F9FAFB;--gray-100:#F3F4F6;--gray-200:#E5E7EB;--gray-500:#6B7280;--gray-700:#374151;--dark:#1A1D2E;
  --fs-xs:11px;--fs-sm:13px;--fs-base:15px;--fs-md:17px;--fs-lg:20px;--fs-xl:26px;--fs-2xl:36px;--fs-3xl:44px;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',sans-serif;background:#EEF0F7;color:var(--dark);font-size:var(--fs-base)}
.hdr{background:#fff;border-bottom:3px solid var(--blue);padding:0 32px;height:62px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 8px rgba(0,0,0,.07);position:sticky;top:0;z-index:200}
.hdr-l{display:flex;align-items:center;gap:16px}
.pill{background:var(--blue);color:#fff;font-size:var(--fs-xs);font-weight:800;letter-spacing:.12em;text-transform:uppercase;padding:5px 13px;border-radius:5px}
.hdr-title{font-size:var(--fs-md);font-weight:800;color:var(--dark)}
.hdr-r{display:flex;gap:24px;font-size:var(--fs-sm);color:var(--gray-500);align-items:center}
.hdr-r b{color:var(--dark);font-weight:700}
.tab-bar{background:#fff;border-bottom:1px solid var(--gray-200);padding:0 32px;display:flex}
.tab-btn{padding:14px 26px;font-size:var(--fs-sm);font-weight:700;color:var(--gray-500);border:none;background:none;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-1px;display:flex;align-items:center;gap:8px;transition:.15s;font-family:inherit}
.tab-btn:hover{color:var(--dark)}.tab-btn.active{color:var(--blue);border-bottom-color:var(--blue)}
.tab-pane{display:none}.tab-pane.active{display:block}
.page{padding:22px 28px 48px;max-width:1700px;margin:0 auto}
.s-lbl{font-size:var(--fs-xs);font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:var(--gray-500);margin:24px 0 13px;display:flex;align-items:center;gap:12px}
.s-lbl::after{content:'';flex:1;height:1px;background:var(--gray-200)}
.card{background:#fff;border-radius:10px;box-shadow:0 1px 5px rgba(0,0,0,.07);overflow:hidden}
.c-head{padding:15px 20px 13px;border-bottom:1px solid var(--gray-100);font-size:var(--fs-xs);font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:var(--gray-500);display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap}
.chl{display:flex;align-items:center;gap:8px}
.c-bar{width:4px;height:16px;border-radius:2px;flex-shrink:0}
.c-body{padding:18px 20px}
.kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}
.kpi-row-4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.kpi{background:#fff;border-radius:10px;box-shadow:0 1px 5px rgba(0,0,0,.07);padding:20px 22px 18px;border-top:4px solid transparent;position:relative}
.kpi.kt{border-top-color:var(--blue)}.kpi.ka{border-top-color:var(--green)}.kpi.kr{border-top-color:var(--red)}.kpi.ki{border-top-color:var(--amber)}.kpi.kp{border-top-color:var(--green)}.kpi.kv{border-top-color:var(--purple)}
.k-lbl{font-size:var(--fs-xs);font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:var(--gray-500);margin-bottom:10px}
.k-val{font-size:var(--fs-3xl);font-weight:900;letter-spacing:-.03em;line-height:1;color:var(--dark)}
.ka .k-val{color:var(--green)}.kr .k-val{color:var(--red)}.ki .k-val{color:var(--amber)}
.k-sub{font-size:var(--fs-sm);color:var(--gray-500);margin-top:8px}
.k-badge{position:absolute;top:18px;right:18px;font-size:var(--fs-sm);font-weight:700;padding:3px 11px;border-radius:20px}
.ka .k-badge{background:#ECFDF5;color:var(--green)}.kr .k-badge{background:#FEF2F2;color:var(--red)}.ki .k-badge{background:#FFFBEB;color:var(--amber)}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.row-main{display:grid;grid-template-columns:1.7fr 1.3fr;gap:12px}
.row-bot{display:grid;grid-template-columns:1.15fr .85fr;gap:12px}
.col-r{display:flex;flex-direction:column;gap:12px}
.tbl{width:100%;border-collapse:collapse}
.tbl th{font-size:var(--fs-xs);font-weight:800;text-transform:uppercase;letter-spacing:.09em;color:var(--gray-500);padding:0 12px 13px 0;text-align:left;border-bottom:2px solid var(--gray-100)}
.tbl th.r{text-align:right}.tbl td{padding:12px 12px 12px 0;border-bottom:1px solid var(--gray-50);vertical-align:middle;font-size:var(--fs-sm)}
.tbl tr:last-child td{border-bottom:none}.tbl tr:hover td{background:var(--gray-50)}
.logo-ph{width:38px;height:22px;border-radius:5px;background:var(--gray-100);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:var(--gray-500)}.logo-box{width:38px;height:22px;border-radius:5px;overflow:hidden;display:flex;align-items:center;justify-content:center;padding:2px;background:#F9FAFB}.logo-box img{max-width:100%;max-height:100%;object-fit:contain}
.co-id{font-size:11px;font-weight:700;color:var(--blue);display:block}.co-nm{font-size:var(--fs-base);font-weight:700;color:var(--dark)}
.nbig{font-size:var(--fs-md);font-weight:900;color:var(--dark)}
.stk{display:flex;height:7px;border-radius:4px;overflow:hidden;gap:1px;width:96px}
.sg{background:var(--green)}.sr{background:var(--red)}.sa{background:var(--amber)}
.pg{color:var(--green);font-weight:800;font-size:var(--fs-sm)}.pr{color:var(--red);font-weight:800;font-size:var(--fs-sm)}.pa{color:var(--amber);font-weight:700;font-size:var(--fs-sm)}
.tr{text-align:right}
.ag-tbl{width:100%;border-collapse:collapse}
.ag-tbl td{padding:11px 0;border-bottom:1px solid var(--gray-50);vertical-align:middle}
.ag-tbl tr:last-child td{border-bottom:none}
.av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;color:#fff;flex-shrink:0}
.av-lg{width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:900;color:#fff;flex-shrink:0}
.anm{font-size:var(--fs-sm);font-weight:700;color:var(--dark)}.asb{font-size:11px;color:var(--gray-500)}
.abg{height:6px;background:var(--gray-100);border-radius:3px}.afl{height:6px;border-radius:3px}
.anum{font-size:var(--fs-base);font-weight:900;color:var(--dark);text-align:right;white-space:nowrap}
.tag{display:inline-block;font-size:11px;font-weight:800;padding:3px 10px;border-radius:5px;white-space:nowrap}
.tok{background:#ECFDF5;color:#059669}.tko{background:#FEF2F2;color:#DC2626}
.twn{background:#FFFBEB;color:#D97706}.tne{background:#EFF6FF;color:var(--blue)}
.tpu{background:#F5F3FF;color:#7C3AED}.terr{background:#FFF1F2;color:#E11D48}
.hbg{height:6px;background:var(--gray-100);border-radius:3px;overflow:hidden;width:84px}
.hfl{height:6px;border-radius:3px}
.hok{background:var(--green)}.hko{background:var(--red)}.hwn{background:var(--amber)}.hne{background:var(--blue)}
.nbold{font-size:var(--fs-sm);font-weight:900;color:var(--dark);text-align:right}
.mini-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px}
.mini{background:var(--gray-50);border-radius:7px;padding:12px 14px;border-left:4px solid var(--gray-200)}
.mini.mg{border-left-color:var(--green)}.mini.mr{border-left-color:var(--red)}.mini.mb{border-left-color:var(--blue)}
.mini-val{font-size:var(--fs-xl);font-weight:900;color:var(--dark)}
.mini-lbl{font-size:11px;color:var(--gray-500);margin-top:3px;font-weight:600}
.footer{background:#fff;border-radius:10px;box-shadow:0 1px 5px rgba(0,0,0,.07);padding:14px 22px;margin-top:12px;display:flex;justify-content:space-between;align-items:center;font-size:var(--fs-sm);color:var(--gray-500);flex-wrap:wrap;gap:8px}
.footer b{color:var(--dark)}.fgr{color:var(--green);font-weight:800}.frd{color:var(--red);font-weight:800}.fbl{color:var(--blue);font-weight:800}
.ag-detail-tbl{width:100%;border-collapse:collapse}
.ag-detail-tbl th{font-size:var(--fs-xs);font-weight:800;text-transform:uppercase;letter-spacing:.09em;color:var(--gray-500);padding:8px 12px 12px 0;text-align:left;border-bottom:2px solid var(--gray-100)}
.ag-detail-tbl th.r{text-align:right}
.ag-detail-tbl td{padding:13px 12px 13px 0;border-bottom:1px solid var(--gray-50);vertical-align:middle;font-size:var(--fs-sm)}
.ag-detail-tbl tr:last-child td{border-bottom:none}.ag-detail-tbl tr:hover td{background:var(--gray-50)}
.rank-badge{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;background:var(--gray-100);color:var(--gray-500)}
.rank-badge.gold{background:#FEF3C7;color:#B45309}.rank-badge.silver{background:#F1F5F9;color:#475569}.rank-badge.bronze{background:#FFEDD5;color:#9A3412}
.score-pill{display:inline-flex;align-items:center;font-size:11px;font-weight:800;padding:3px 11px;border-radius:20px}
.score-hi{background:#ECFDF5;color:#059669}.score-md{background:#FFF7ED;color:#D97706}.score-lo{background:#FEF2F2;color:#DC2626}
.ag-selector{display:flex;gap:6px;flex-wrap:wrap}
.ag-sel-btn{padding:6px 14px;border-radius:20px;border:1.5px solid var(--gray-200);background:#fff;font-size:var(--fs-sm);font-weight:700;color:var(--gray-500);cursor:pointer;transition:.15s;font-family:inherit}
.ag-sel-btn:hover{border-color:var(--blue);color:var(--blue)}.ag-sel-btn.active{background:var(--blue);border-color:var(--blue);color:#fff}
.agent-card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px}
.agent-card{background:#fff;border-radius:10px;box-shadow:0 1px 5px rgba(0,0,0,.07);padding:20px 20px 16px;border-top:5px solid var(--blue)}
.agent-card-top{display:flex;align-items:center;gap:14px;margin-bottom:16px}
.agent-card-name{font-size:var(--fs-base);font-weight:800;color:var(--dark)}
.agent-card-sub{font-size:var(--fs-sm);color:var(--gray-500);margin-top:2px}
.agent-card-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px}
.acs{background:var(--gray-50);border-radius:6px;padding:10px 12px;text-align:center}
.acs-val{font-size:var(--fs-lg);font-weight:900;color:var(--dark)}.acs-lbl{font-size:11px;color:var(--gray-500);text-transform:uppercase;letter-spacing:.07em;margin-top:2px;font-weight:700}
.acs-apr .acs-val{color:var(--green)}.acs-rej .acs-val{color:var(--red)}
.acb-track{height:8px;background:var(--gray-100);border-radius:4px;overflow:hidden;display:flex;margin-top:14px}
.acb-g{background:var(--green);height:8px}.acb-r{background:var(--red);height:8px}.acb-a{background:var(--amber);height:8px}
.mot-main{font-size:var(--fs-sm);font-weight:700;color:var(--dark)}
.mot-sub{font-size:12px;color:var(--gray-500);margin-top:2px;font-style:italic}
.modal-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center}
.modal-ov.open{display:flex}
.modal-box{background:#fff;border-radius:14px;padding:32px 36px;max-width:580px;width:92%;box-shadow:0 24px 64px rgba(0,0,0,.22);max-height:90vh;overflow-y:auto}
.modal-box h3{font-size:var(--fs-md);font-weight:800;color:var(--dark);margin-bottom:6px}
.modal-box p.sub{font-size:var(--fs-sm);color:var(--gray-500);margin-bottom:20px}
.drop-zone{border:2px dashed var(--gray-200);border-radius:10px;padding:32px;text-align:center;cursor:pointer;transition:.2s;margin-bottom:16px}
.drop-zone:hover,.drop-zone.drag{border-color:var(--blue);background:#EFF6FF}
.drop-zone p{font-size:var(--fs-sm);color:var(--gray-500);margin:8px 0 0}.drop-zone strong{color:var(--blue)}
.col-map{display:none}
.col-map-title{font-size:var(--fs-xs);font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:var(--gray-500);margin:16px 0 12px}
.col-row{display:grid;grid-template-columns:160px 1fr;gap:10px;align-items:center;margin-bottom:8px}
.col-row label{font-size:var(--fs-sm);font-weight:700;color:var(--gray-700)}
.col-row select{border:1.5px solid var(--gray-200);border-radius:6px;padding:6px 10px;font-size:var(--fs-sm);color:var(--dark);font-family:inherit;background:#fff;width:100%}
.modal-btns{display:flex;gap:12px;justify-content:flex-end;margin-top:20px}
.btn{padding:10px 22px;border-radius:7px;font-size:var(--fs-sm);font-weight:700;cursor:pointer;border:none;font-family:inherit;transition:.15s}
.btn-primary{background:var(--blue);color:#fff}.btn-primary:hover{background:#2563EB}
.btn-secondary{background:var(--gray-100);color:var(--gray-700)}.btn-secondary:hover{background:var(--gray-200)}
.upload-btn{background:var(--blue);color:#fff;border:none;padding:8px 16px;border-radius:6px;font-size:var(--fs-sm);font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:7px;transition:.15s}
.upload-btn:hover{background:#2563EB}
.upload-ok{font-size:var(--fs-sm);color:var(--green);font-weight:700;display:none;align-items:center;gap:5px}
.sla-ok{color:var(--green);font-weight:800}.sla-warn{color:var(--amber);font-weight:800}.sla-bad{color:var(--red);font-weight:800}
.file-info{margin-top:8px;font-size:var(--fs-sm);color:var(--blue);display:none}
</style>
</head>
<body>
<div class="hdr">
  <div class="hdr-l">
    <span class="pill">HIL 2026</span>
    <span class="hdr-title">Human in the Loop &mdash; Dashboard de Comportamiento</span>
  </div>
  <div class="hdr-r">
    <span>Periodo: <b id="hdr-periodo">Enero &ndash; Marzo 2026</b></span>
    <span>Plataforma: <b>Jelou AI</b></span>
    <span>Promedio diario: <b id="hdr-prom">485 casos</b></span>
    <span>Registros: <b id="hdr-total">31,512</b></span>
    <span class="upload-ok" id="upload-ok">Datos actualizados</span>
    <button class="upload-btn" onclick="openModal()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      Cargar Excel
    </button>
  </div>
</div>
<div class="tab-bar">
  <button class="tab-btn active" onclick="switchTab('general',this)">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    Resumen General
  </button>
  <button class="tab-btn" onclick="switchTab('motivos',this)">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    Motivos de Revision
  </button>
  <button class="tab-btn" onclick="switchTab('tiempo',this)">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    Tiempos y Actividad
  </button>
  <button class="tab-btn" onclick="switchTab('agentes',this)">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    Analisis de Agentes
  </button>
</div>

<div class="modal-ov" id="modal-ov">
  <div class="modal-box">
    <h3>Actualizar datos desde Excel</h3>
    <p class="sub">Sube un archivo <strong>.xlsx</strong> o <strong>.csv</strong> con los datos depurados.</p>
    <div class="drop-zone" id="drop-zone" onclick="document.getElementById('file-inp').click()">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.5" style="margin:0 auto 10px;display:block"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg>
      <p>Haz clic o arrastra tu archivo aqui<br><strong>Excel (.xlsx, .xls) o CSV</strong></p>
      <p class="file-info" id="file-info"></p>
    </div>
    <input type="file" id="file-inp" accept=".xlsx,.xls,.csv" style="display:none" onchange="handleFile(this.files[0])">
    <div class="col-map" id="col-map">
      <div class="col-map-title">Mapeo de Columnas</div>
      <div class="col-row"><label>Fecha Creacion</label><select id="mp-fecha"><option value="">No incluida</option></select></div>
      <div class="col-row"><label>Ultima Actualizacion</label><select id="mp-fechau"><option value="">No incluida</option></select></div>
      <div class="col-row"><label>Resultado / Estado</label><select id="mp-resultado"><option value="">No incluida</option></select></div>
      <div class="col-row"><label>Empresa / CompanyID</label><select id="mp-empresa"><option value="">No incluida</option></select></div>
      <div class="col-row"><label>Agente Asignado</label><select id="mp-agente"><option value="">No incluida</option></select></div>
      <div class="col-row"><label>Comentario del Agente</label><select id="mp-comentario"><option value="">No incluida</option></select></div>
      <div class="col-row"><label>Descripcion / Motivo</label><select id="mp-motivo"><option value="">No incluida</option></select></div>
      <div class="col-row"><label>Tipo de Paso (Step)</label><select id="mp-step"><option value="">No incluida</option></select></div>
    </div>
    <div class="modal-btns">
      <button class="btn btn-secondary" onclick="closeModal()">Cancelar</button>
      <button class="btn btn-primary" id="btn-apply" style="display:none" onclick="applyData()">Aplicar al dashboard</button>
    </div>
  </div>
</div>

<div id="tab-general" class="tab-pane active">
<div class="page">
  <div class="s-lbl">Resumen General</div>
  <div class="kpi-row">
    <div class="kpi kt"><div class="k-lbl">Total Casos</div><div class="k-val" id="kpi-total">31,512</div><div class="k-sub" id="kpi-total-sub">Enero &ndash; Marzo 2026</div></div>
    <div class="kpi ka"><span class="k-badge" id="kpi-apr-badge">72.3%</span><div class="k-lbl">Aprobados</div><div class="k-val" id="kpi-apr">22,772</div><div class="k-sub">del total procesado</div></div>
    <div class="kpi kr"><span class="k-badge" id="kpi-rej-badge">24.8%</span><div class="k-lbl">Rechazados</div><div class="k-val" id="kpi-rej">7,802</div><div class="k-sub">del total procesado</div></div>
    <div class="kpi ki"><span class="k-badge" id="kpi-inc-badge">3.0%</span><div class="k-lbl">Incompletos</div><div class="k-val" id="kpi-inc">938</div><div class="k-sub">del total procesado</div></div>
    <div class="kpi kp"><div class="k-lbl">Promedio Diario</div><div class="k-val" id="kpi-prom">485</div><div class="k-sub" id="kpi-prom-sub">Max: 695 casos</div></div>
  </div>
  <div class="s-lbl">Tendencia y Actividad</div>
  <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:12px">
    <div class="card"><div class="c-head"><div class="chl"><span class="c-bar" style="background:var(--blue)"></span>Volumen Diario &mdash; Aprobados vs Rechazados</div></div><div class="c-body"><div style="position:relative;height:210px"><canvas id="chDia"></canvas></div></div></div>
    <div class="card"><div class="c-head"><div class="chl"><span class="c-bar" style="background:var(--amber)"></span>Casos por Dia de la Semana</div></div><div class="c-body"><div style="position:relative;height:210px"><canvas id="chDow"></canvas></div></div></div>
