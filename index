function fmt(n){return Number(n).toLocaleString('es');}
function pct(a,t){return t?((a/t)*100).toFixed(1)+'%':'0%';}
function pctN(a,t){return t?parseFloat(((a/t)*100).toFixed(1)):0;}
function ini(name){return String(name).split(/[\s._@\-]/).slice(0,2).map(function(w){return w[0]||'';}).join('').toUpperCase().slice(0,2)||'??';}
function secToMin(s){return s?+(s/60).toFixed(1):0;}
function minStr(s){if(!s||s===0)return 'N/A';var m=secToMin(s);return m>=60?''+(m/60).toFixed(1)+'h':m<1?s+'s':m.toFixed(1)+'min';}
