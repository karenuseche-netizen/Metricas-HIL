  var over5=0;Object.entries(tb).forEach(function(e){if(e[0]==='5-10min'||e[0]==='> 10min')over5+=e[1];});
  var totalT=Object.values(tb).reduce(function(a,b){return a+b;},0)||1;
  var slaOk=d.slaPct||96.2;

  // Update KPIs — t-avg shows median (representative), t-med shows mean
  var avgEl=document.getElementById('t-avg');if(avgEl)avgEl.textContent=medT+'s';
