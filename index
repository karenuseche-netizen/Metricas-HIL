  var slowEl=document.getElementById('t-slow');if(slowEl)slowEl.textContent=((over5/totalT)*100).toFixed(1)+'%';

  // Time buckets chart with SLA annotation
  var bucketLabels=Object.keys(tb);var bucketVals=Object.values(tb);
  var bucketColors=bucketLabels.map(function(l){
    return l==='< 30s'||l==='30s-1min'||l==='1-2min'||l==='2-5min'?'#10B981':
           l==='5-10min'?'#F59E0B':'#EF4444';
